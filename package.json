{
  "name": "qtttweb",
  "version": "1.0.0",
  "description": "QuantumGame",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "start:staging": "node --env-file=.env.staging server/index.js",
    "start:production": "node --env-file=.env.production server/index.js",
    "dev": "nodemon server/index.js",
    "db:init": "node server/persistence/initDb.js",
    "db:init:staging": "node --env-file=.env.staging server/persistence/initDb.js",
    "db:init:production": "node --env-file=.env.production server/persistence/initDb.js",
    "db:expire": "node server/persistence/runExpiryJob.js",
    "db:expire:staging": "node --env-file=.env.staging server/persistence/runExpiryJob.js",
    "db:expire:production": "node --env-file=.env.production server/persistence/runExpiryJob.js",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "author": "ChrisA",
  "license": "ISC",
  "dependencies": {
    "compression": "^1.8.1",
    "ejs": "^3.1.8",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.16.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
